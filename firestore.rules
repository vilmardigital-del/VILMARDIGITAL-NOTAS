rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidSong(data) {
      return data.keys().hasAll(['title', 'content', 'category']) &&
             data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 10000 &&
             data.category in ["Entrada", "Perdão", "Glória", "Santo", "Aleluia", "Salmos", "Cordeiro", "Comum", "Ofertório", "Final"] &&
             (!('youtubeUrl' in data) || (data.youtubeUrl is string && data.youtubeUrl.size() <= 500));
    }

    function isValidPlaylist(data) {
      return data.keys().hasAll(['title', 'songIds']) &&
             data.title is string && data.title.size() <= 200 &&
             data.songIds is list && data.songIds.size() <= 50;
    }

    match /songs/{songId} {
      allow read: if true;
      allow create: if isValidSong(request.resource.data);
      allow update: if isValidSong(request.resource.data);
      allow delete: if true;
    }

    match /playlists/{playlistId} {
      allow read: if true;
      allow create: if isValidPlaylist(request.resource.data);
      allow update: if isValidPlaylist(request.resource.data);
      allow delete: if true;
    }
  }
}
