rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidSong(data) {
      return data.keys().hasAll(['title', 'content', 'category']) &&
             data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 10000 &&
             data.category in ["Entrada", "Perdão", "Glória", "Santo", "Aleluia", "Salmos", "Cordeiro", "Comum", "Ofertório", "Comunhão", "Final", "Grupo de Oração", "Espírito Santo", "Louvor", "Mariana", "Entrega", "Adoração"] &&
             (!('youtubeUrl' in data) || (data.youtubeUrl is string && data.youtubeUrl.size() <= 500));
    }

    function isValidPlaylist(data) {
      return data.keys().hasAll(['title', 'songIds']) &&
             data.title is string && data.title.size() <= 200 &&
             data.songIds is list && data.songIds.size() <= 60 &&
             (!('transpositions' in data) || data.transpositions is map);
    }

    function isValidAccessUser(data) {
      return data.keys().hasAll(['name', 'password', 'role', 'createdAt']) &&
             data.name is string && data.name.size() <= 100 &&
             data.password is string && data.password.size() <= 100 &&
             data.role in ['master', 'admin', 'viewer'] &&
             (!('currentSessionId' in data) || data.currentSessionId == null || (data.currentSessionId is string && data.currentSessionId.size() <= 128)) &&
             (!('isOnline' in data) || data.isOnline is bool) &&
             (!('lastActive' in data) || data.lastActive == null || data.lastActive is int);
    }

    function isValidMassaPhoto(data) {
      return data.keys().hasAll(['url', 'date']) &&
             data.url is string && data.url.size() <= 3000000 &&
             data.date is string && data.date.size() <= 200 &&
             (!('storagePath' in data) || data.storagePath == null || (data.storagePath is string && data.storagePath.size() <= 1000)) &&
             (!('description' in data) || (data.description is string && data.description.size() <= 2000)) &&
             (!('isBase64' in data) || data.isBase64 is bool) &&
             (!('isBanner' in data) || data.isBanner is bool) &&
             (!('createdAt' in data) || data.createdAt == null || data.createdAt is timestamp);
    }

    match /songs/{songId} {
      allow read: if true;
      allow create: if isValidSong(request.resource.data);
      allow update: if isValidSong(request.resource.data);
      allow delete: if true;
    }

    match /playlists/{playlistId} {
      allow read: if true;
      allow create: if isValidPlaylist(request.resource.data);
      allow update: if isValidPlaylist(request.resource.data);
      allow delete: if true;
    }

    match /access_users/{userId} {
      allow read: if true;
      allow create: if isValidAccessUser(request.resource.data);
      allow update: if isValidAccessUser(request.resource.data);
      allow delete: if true;
    }

    match /events/{eventId} {
      allow read: if true;
      allow write: if true;
    }

    match /massa_photos/{photoId} {
      allow read: if true;
      allow create: if isValidMassaPhoto(request.resource.data);
      allow update: if isValidMassaPhoto(request.resource.data);
      allow delete: if true;
    }

    match /visits/{visitId} {
      allow read, write: if true;
    }
  }
}
